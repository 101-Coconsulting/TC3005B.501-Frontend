---
/**
*Author: Hector Julian Zarate Ramirez
*
*Description: This script is used to create a page that allows the user to edit a request, based on the id passed in the URL.
*
**/
import MainLayout from "@layouts/MainLayout.astro";
import EditRequest from "@components/EditRequest.astro";
import type { UserRole } from "@type/roles";

// Change back to prerender = false to make this a dynamic route
export const prerender = false;

import { getCookie } from "@data/cookies";
import { roleLabels } from "@config/role-labels";

const role: UserRole = getCookie("role") as UserRole;
const userName = getCookie("username");
const buttonLabel = roleLabels[role];

// FETCH API DATA
import { apiRequest } from "@utils/apiClient";

// Uncomment getStaticPaths to provide static paths during build
export async function getStaticPaths() {
  // Return a minimal set of paths to satisfy the build
  return [
    { params: { id: "1" } },
    { params: { id: "2" } },
    { params: { id: "3" } }
  ];
}

const { id } = Astro.params;
// Move API call to be executed at request time, not build time
let request;
try {
  if (Astro.request.method !== "HEAD") { // Skip during build
    request = await apiRequest(`/applicant/get-user-request/${id}`);
  }
} catch (error) {
  console.error("Error fetching request:", error);
}
---

<MainLayout title={`Editar solicitud #${request?.request_id || id}`} data={{ userName, buttonLabel, role }} >
  {request ? <EditRequest request={request} /> : <div>Loading request data...</div>}
</MainLayout>
