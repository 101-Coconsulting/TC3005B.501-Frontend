---
/**
 * Author: Julia Maria Stephanie Duenkelsbuehler Castillo Y Nicole Davila
 * 
 * Description: This Astro page renders an application approval screen.
 * It includes sections for travel details and buttons for authorization and rejection.
 */

import MainLayout from "@layouts/MainLayout.astro";
import RequestApproval from "@components/RequestApproval.astro";
import type { UserRole } from "@type/roles";

import { getCookie } from "@data/cookies";
import { roleLabels } from "@config/role-labels";

const role: UserRole = getCookie("role") as UserRole;
const userName = getCookie("username");
const buttonLabel = roleLabels[role];

import { apiRequest } from '@utils/apiClient';

// Uncomment getStaticPaths to provide static paths during build
export async function getStaticPaths() {
  // Return a minimal set of paths to satisfy the build
  return [
    { params: { id: "1" } },
    { params: { id: "2" } },
    { params: { id: "3" } }
  ];
}

// Change back to prerender = false to make this a dynamic route
export const prerender = false;

const { id } = Astro.params;
// Move API call to be executed at request time, not build time
let request;
try {
  if (Astro.request.method !== "HEAD") { // Skip during build
    request = await apiRequest(`/user/get-travel-request/${id}`);
  }
} catch (error) {
  console.error("Error fetching request:", error);
}
---

<MainLayout title={`Solicitud #${request?.request_id || id}`} data={{ userName, buttonLabel, role }} >
  {request ? <RequestApproval request={request} /> : <div>Loading request data...</div>}
</MainLayout>
